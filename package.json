{
  "name": "macrokeep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev --port 8788 -- env -u VITE_DEV_API_PROXY_TARGET npm run dev:vite",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && wrangler pages deploy dist",
    "preview:pages": "npm run build && wrangler pages dev dist",
    "preview": "vite preview",
    "lint": "eslint .",
    "generate:pwa": "node scripts/generate-pwa-assets.mjs",
    "dev:marketing": "npm run dev --prefix marketing",
    "build:marketing": "npm run build --prefix marketing"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-router": "^1.139.11",
    "i18next": "^26.2.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.19.0"
  }
