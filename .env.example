# --- Google OAuth (Web application client) ---
# Authorized redirect URI must be: {OM_SITE_ORIGIN}/api/auth/google/callback
# OAuth consent screen: drive.appdata, openid, email, profile
#
# Server-only (Vercel environment variables):
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
#
# Public site URL for redirects (no trailing slash), e.g. https://your-app.vercel.app
# OM_SITE_ORIGIN=
#
# Firestore: full service account JSON on one line (or minified .json). Needs literal \n inside private_key when line-wrapped.
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
#
# AES-256-GCM key for encrypting refresh tokens at rest (32 raw bytes, base64):
#   openssl rand -base64 32
# TOKEN_ENCRYPTION_KEY=

# --- Local dev ---
# Run `vercel dev` on another port and point Vite at it so `/api` works:
# VITE_DEV_API_PROXY_TARGET=http://localhost:3000
