# Create an OAuth 2.0 Client ID (type: Web application). OpenMacro uses Google
# Identity Services (GIS), not the deprecated gapi.auth2 library.
# Enable Google Drive API; add authorized JavaScript origins for dev/prod.
# OAuth consent screen: include scopes drive.appdata, email, profile, openid.
VITE_GOOGLE_CLIENT_ID=

# Optional — Gemini model id for the scanner (default: gemini-2.5-flash).
# https://ai.google.dev/gemini-api/docs/models
# VITE_GEMINI_MODEL=
