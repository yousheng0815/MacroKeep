---
import LandingPageContent from "../../components/LandingPageContent.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { localizedPath } from "../../i18n/config";
import { getMessages } from "../../i18n";
import { buildLandingStructuredData } from "../../lib/structured-data";

const messages = getMessages("en");
const page = messages.landingPages.myfitnesspalAlternative;
const pathname = page.path;
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="en"
  messages={messages}
  pathname={pathname}
  structuredData={buildLandingStructuredData(
    page,
    new URL(pathname, Astro.site).href,
    messages.locale,
    localizedPath(messages.locale, "/"),
  )}
>
  <LandingPageContent
    page={page}
    messages={messages}
    homePath={localizedPath("en", "/")}
  />
</BaseLayout>
