---
import LegalDocument from "../components/LegalDocument.astro";
import { termsOfServiceEn } from "@legal/terms-of-service";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Terms of Service"
  description="Terms governing your use of MacroKeep."
>
  <main class="container" style="padding-block: 2.5rem 4rem">
    <p style="margin: 0 0 1rem; font-size: 0.875rem">
      <a href="/" class="muted" style="text-decoration: none">← Home</a>
    </p>
    <h1 style="margin: 0; font-size: 1.75rem; font-weight: 700">Terms of Service</h1>
    <div style="margin-top: 1.5rem">
      <LegalDocument doc={termsOfServiceEn} />
    </div>
  </main>
</BaseLayout>
