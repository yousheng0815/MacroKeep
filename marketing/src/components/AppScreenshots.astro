---
import type { MarketingMessages } from "../i18n/types";

interface Props {
  messages: MarketingMessages;
}

const { messages } = Astro.props;
const { items } = messages.screenshots;
---

<section class="screenshots-section" aria-labelledby="screenshots-heading">
  <div class="container">
    <h2 id="screenshots-heading" class="screenshots-heading">{messages.screenshots.heading}</h2>
    <p class="screenshots-lead muted">{messages.screenshots.lead}</p>

    <div class="screenshots-scroll-wrap">
      <ul
        id="screenshots-strip"
        class="screenshots-strip"
        aria-label={messages.screenshots.stripLabel}
      >
        {
          items.map((shot) => (
            <li
              class={`screenshot-slide${shot.id === "today" ? " screenshot-slide--today" : ""}`}
              id={shot.id === "today" ? "screenshot-today" : undefined}
              data-screenshot={shot.id}
            >
              <figure class="screenshot-card">
                <div class="screenshot-frame">
                  <img
                    src={shot.src}
                    alt={shot.alt}
                    width={390}
                    height={844}
                    loading={shot.id === "today" ? "eager" : "lazy"}
                    fetchpriority={shot.id === "today" ? "high" : "auto"}
                    decoding="async"
                  />
                </div>
                <figcaption class="screenshot-label">{shot.label}</figcaption>
              </figure>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script>
  const MOBILE_MQ = "(max-width: 899px)";

  function centerTodayInStrip() {
    if (!window.matchMedia(MOBILE_MQ).matches) return;

    const strip = document.getElementById("screenshots-strip");
    const today = document.getElementById("screenshot-today");
    if (!strip || !today) return;

    const target =
      today.offsetLeft - (strip.clientWidth - today.offsetWidth) / 2;
    strip.scrollLeft = Math.max(0, target);
  }

  function scheduleCenterToday() {
    requestAnimationFrame(() => {
      centerTodayInStrip();
      requestAnimationFrame(centerTodayInStrip);
    });
  }

  scheduleCenterToday();
  window.addEventListener("load", scheduleCenterToday, { once: true });

  document
    .getElementById("screenshots-strip")
    ?.querySelectorAll("img")
    .forEach((img) => {
      if (img.complete) return;
      img.addEventListener("load", scheduleCenterToday, { once: true });
    });
</script>
