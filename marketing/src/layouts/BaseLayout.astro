---
import "../styles/global.css";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import LocaleAutoRedirect from "../components/LocaleAutoRedirect.astro";
import type { MarketingLocale } from "../i18n/config";
import { documentLangAttr, localizedPath } from "../i18n/config";
import type { MarketingMessages } from "../i18n/types";
import { APP_URL } from "../site";

interface Props {
  title: string;
  description: string;
  locale: MarketingLocale;
  messages: MarketingMessages;
  pathname?: string;
  structuredData?: Record<string, unknown>;
}

const { title, description, locale, messages, pathname = Astro.url.pathname, structuredData } =
  Astro.props;
const pageUrl = new URL(pathname, Astro.site).href;
const fullTitle =
  title.startsWith("MacroKeep") || title.endsWith("MacroKeep")
    ? title
    : `${title} · MacroKeep`;
const ogImage = new URL("/screenshots/today.png", Astro.site).href;
const homePath = localizedPath(locale, "/");
const privacyPath = localizedPath(locale, "/privacy");
const termsPath = localizedPath(locale, "/terms");
const enPath = localizedPath("en", pathname);
const zhTwPath = localizedPath("zh-TW", pathname);
const ogLocale = locale === "zh-TW" ? "zh_TW" : "en_US";
const ogLocaleAlternate = locale === "zh-TW" ? "en_US" : "zh_TW";
---

<!doctype html>
<html lang={documentLangAttr(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090B" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MacroKeep" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, Astro.site).href} />
    <link rel="alternate" hreflang="zh-Hant" href={new URL(zhTwPath, Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(enPath, Astro.site).href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    {
      structuredData ? (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      ) : null
    }
    <LocaleAutoRedirect />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href={homePath} class="site-header__logo">
          <img src="/wordmark.png" alt="MacroKeep" width="140" height="32" />
        </a>
        <a class="btn btn-primary site-header__cta" href={APP_URL}>{messages.nav.openApp}</a>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div class="site-footer__top">
          <p class="site-footer__copy muted">
            © {new Date().getFullYear()} MacroKeep
          </p>
          <LanguageSwitcher
            locale={locale}
            messages={messages}
            pathname={pathname}
            class="lang-switcher--footer"
          />
        </div>
        <nav class="site-footer__links" aria-label="Footer">
          <a href={privacyPath}>{messages.footer.privacy}</a>
          <a href={termsPath}>{messages.footer.terms}</a>
          <a href={APP_URL}>{messages.nav.openApp}</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
